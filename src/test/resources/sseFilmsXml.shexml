PREFIX : <http://example.com/>
STREAM films_stream <http://localhost:8003/films>
ITERATOR event <xpath: /sse> {
  FIELD id <id>
  ITERATOR film <data/films/film> {
    FIELD name <name>
    FIELD year <year>
  }
}


EXPRESSION films <films_stream.event>

:Films :[films.id] {
  :type :Film ;
  :name [films.film.name] ;
  :year [films.film.year] ;
}